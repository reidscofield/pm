# Hydro-Wates PM app — environment variables.
# Copy this file to ".env" and fill in the values to switch storage from local
# JSON files to Supabase (required for Vercel; optional locally for testing).
#
# Leave these UNSET to keep using local data/*.json files (the default).

# Your Supabase project URL (Supabase dashboard -> Settings -> API -> Project URL)
SUPABASE_URL=https://vpdcikiyaifppkkantrb.supabase.co

# The SERVICE-ROLE key (Settings -> API -> Project API keys -> service_role "secret").
# Server-side ONLY — it bypasses RLS. NEVER expose it to the browser or commit it.
SUPABASE_SERVICE_KEY=

# ---- login (Phase 2) ---------------------------------------------------------
# Turn login ON by setting this to true. Off/unset = no login (handy for local dev).
# It is set to true in the Vercel deployment so only signed-in staff can get in.
# REQUIRE_AUTH=true

# Only emails on this domain may sign in (defaults to hydrowates.com). The browser
# also needs the project's ANON key — it falls back to the Shop Master key already
# in settings, so you usually don't need to set SUPABASE_ANON_KEY explicitly.
# ALLOWED_EMAIL_DOMAIN=hydrowates.com
# SUPABASE_ANON_KEY=
